        <mxCell id="oTicWOi_8jA28Bm3NspU-348" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Evidence.md&lt;/h1&gt;&lt;p&gt;São arquivos que o agente deve ir criando no review, indicando o que foi verificado, o que foi aprovado e o que foi reprovado. Serve como evidências do workflow&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;movable=1;resizable=1;rotatable=1;deletable=1;editable=1;locked=0;connectable=1;" vertex="1" parent="oTicWOi_8jA28Bm3NspU-351">
