@startuml action-gates
title WorkflowDev — Conclusão por Gate

start
:IA solicita AWAITING ou CLOSED;
:statusIssue carrega Issue;
:completeIssue seleciona Gate pela Action;
:Gate declara Artifact, execução e aprovação;

switch (Action)
case (Planning)
  :validar RequirementArtifact
  + filha Design por Feature;
case (Design)
  :validar decisão arquitetural,
  pacote UML, Plan e filha Implement;
case (Implement)
  :validar Worktree e, quando configurados,
  ordem TDD e checks do Projeto;
case (Review)
  :exigir Artifact doc próprio;
case (Deploy)
  :exigir link de PR + análise;
endswitch

if (entrega inválida?) then (sim)
  :GateAssessment rejected;
  :DomainError / DesignGateError;
  stop
endif

:GatePolicy avalia tags e regras do Gate;
if (decisão humana obrigatória?) then (sim)
  :GateAssessment human-required;
  if (destino solicitado = CLOSED?) then (sim)
    :bloquear; orientar AWAITING;
    stop
  else (não)
    :Issue.submit -> AWAITING;
  endif
else (não)
  :GateAssessment approved;
  if (destino solicitado = CLOSED?) then (sim)
    :Issue.closeByAgent -> CLOSED;
  else (não)
    :Issue.submit -> AWAITING;
  endif
endif

:Queue.save;
stop

note right
  Regras human-required:
  HITL, risco ALTO, complexidade ALTA,
  mudança arquitetural ou Deploy.
end note
@enduml
