{
  "name": "@jimmypgomes/issues-local",
  "version": "0.1.0",
  "description": "Issues manager local (CLI + web) com pack de skills SDLC para agentes (claude-code, cursor, codex, pi)",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "issues": "bin/issues"
  },
  "files": [
    "bin",
    "dist",
    "skills",
    "AGENTS.md"
  ],
  "scripts": {
    "test": "node --import tsx --test test/**/*.test.ts",
    "test:mutation": "stryker run",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json && node -e \"require('node:fs').cpSync('src/web/client','dist/src/web/client',{recursive:true})\"",
    "prepare": "npm run build",
    "check:fitness": "node --import tsx --test test/architecture/fitness.test.ts",
    "skills:link": "node --import tsx -e \"import { linkPackSkillsForDogfood } from './src/app/init_pack_use_case.ts'; for (const line of linkPackSkillsForDogfood()) console.log(line)\""
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/tap-runner": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0"
  }
}
